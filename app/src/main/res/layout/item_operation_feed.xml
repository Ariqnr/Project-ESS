<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:baselineAligned="false"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batch #A4-099"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Station 4 • OP: Marcus Chen"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Status Pill ala Azure Manufacturing -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/status_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="@color/green_status_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">
        <TextView
            android:id="@+id/text_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="PASSED"
            android:textColor="@color/green_status_text"
            android:textSize="10sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/text_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14:20"
        android:textColor="@color/outline"
        android:textSize="11sp"
        android:fontFamily="sans-serif-light" />
</LinearLayout>