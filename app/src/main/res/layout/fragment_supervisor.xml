<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="100dp">

        <!-- Welcome Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/secondary"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ringkasan Shift A"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sistem normal. Target tercapai 84%."
                        android:textColor="@color/white"
                        android:alpha="0.9"
                        android:textSize="14sp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_alignParentEnd="true"
                    android:alpha="0.1"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/white"
                    android:contentDescription="Monitoring Icon" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Metric: Status Stok -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Stok Gudang"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progress_stock_circular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="70"
                        app:indicatorColor="@color/secondary"
                        app:indicatorSize="80dp"
                        app:trackColor="@color/primary_container"
                        app:trackThickness="10dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stock_total_units"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1,240 Units"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_stock_raw_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bahan Baku (70%)"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Timeline Produksi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="Timeline Produksi"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barang Dirakit (Panel-X2)"
                        android:textColor="@color/on_surface"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_production_percentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="75%"
                        android:textColor="@color/secondary"
                        android:textStyle="bold" />
                </RelativeLayout>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_production_timeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="75"
                    app:indicatorColor="@color/secondary"
                    app:trackColor="@color/primary_container"
                    app:trackCornerRadius="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quality Analytics (Mock Line Chart) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoring Pengujian Barang"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="horizontal"
                    android:gravity="bottom|center_horizontal"
                    android:padding="8dp">

                    <!-- Bar Lulus QC -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal|bottom"
                        android:layout_marginEnd="48dp">
                        <TextView
                            android:id="@+id/tv_chart_passed_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/green_status_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <View
                            android:id="@+id/view_chart_passed_bar"
                            android:layout_width="50dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="4dp"
                            android:background="@color/green_status_bg" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Lulus QC"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <!-- Bar Gagal QC -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal|bottom">
                        <TextView
                            android:id="@+id/tv_chart_rejected_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/error"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <View
                            android:id="@+id/view_chart_rejected_bar"
                            android:layout_width="50dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="4dp"
                            android:background="@color/error_container" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Gagal QC"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>